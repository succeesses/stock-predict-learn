# 本地长期自选股列表（优先级低于 --stocks / Run workflow 的 stocks）
STOCK_LIST=600519,000001

# CI 核心键（.github/workflows/justice_plutus_analysis.yml 默认会读取）
TUSHARE_TOKEN=
AIHUBMIX_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gemini-flash-lite-latest
LITELLM_MODEL=openai/gemini-flash-lite-latest
LITELLM_FALLBACK_MODELS=openai/gpt-4o-mini
BOCHA_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
IFIND_REFRESH_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REPORT_TYPE=simple
MAX_WORKERS=1
ENABLE_CHIP_DISTRIBUTION=false
# 同花顺专业数据总开关：打开后，能走 THS/iFinD 的结构化数据就优先走
ENABLE_THS_PRO_DATA=false
ENABLE_IFIND=false
ENABLE_IFIND_ANALYSIS_ENHANCEMENT=false
# 筹码数据源（按顺序降级：HSCloud -> Wencai -> AkShare）
HSCLOUD_BASE_URL=https://sandbox.hscloud.cn
HSCLOUD_AUTH_TOKEN=
HSCLOUD_COOKIE=
HSCLOUD_TIMEOUT_SECONDS=8
# 可选：若不想手动维护 token，可配置 app_key/app_secret 自动换取 access_token
HSCLOUD_APP_KEY=
HSCLOUD_APP_SECRET=
WENCAI_COOKIE=
WENCAI_USER_AGENT=

# LLM 扩展（按需启用）
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Data 扩展
REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# 通知扩展（默认 workflow 不注入，启用对应通道时再配置）
WECHAT_WEBHOOK_URL=
WECHAT_MSG_TYPE=markdown
# 飞书群自定义机器人 Webhook；用于把分析结果直接推送到飞书群
FEISHU_WEBHOOK_URL=
TELEGRAM_MESSAGE_THREAD_ID=
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECEIVERS=
EMAIL_SENDER_NAME=justice_plutus
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=
PUSHPLUS_TOKEN=
CUSTOM_WEBHOOK_URLS=
CUSTOM_WEBHOOK_BEARER_TOKEN=
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_MAIN_CHANNEL_ID=
ASTRBOT_URL=
ASTRBOT_TOKEN=
SERVERCHAN3_SENDKEY=
APPEND_IMAGE_AFTER_TEXT_NOTIFY=false

# Runtime 扩展
# 飞书单条消息字节上限；超长内容会自动分批发送
FEISHU_MAX_BYTES=20000
